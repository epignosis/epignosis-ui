{
  "name": "epignosis-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Epignosis shared UI workspace — tokens, React components, Vue components.",
  "author": "Alexander Antoniades <xanderantoniadis@gmail.com>",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter @epignosis_llc/ui-tokens --filter @epignosis_llc/ui-icons --filter @epignosis_llc/ui-react --filter @epignosis_llc/ui-vue run build",
    "storybook:react": "pnpm --filter @epignosis_llc/ui-react storybook",
    "storybook:vue": "pnpm --filter @epignosis_llc/ui-vue storybook",
    "storybook:tokens": "pnpm --filter @epignosis_llc/ui-tokens storybook",
    "storybook:icons": "pnpm --filter @epignosis_llc/ui-icons storybook",
    "storybook:hub": "pnpm --filter @epignosis_llc/ui-hub storybook",
    "storybook:all": "pnpm -r --parallel --filter @epignosis_llc/ui-react --filter @epignosis_llc/ui-vue --filter @epignosis_llc/ui-tokens --filter @epignosis_llc/ui-icons --filter @epignosis_llc/ui-hub run storybook",
    "build-storybook": "pnpm -r --filter @epignosis_llc/ui-react --filter @epignosis_llc/ui-vue --filter @epignosis_llc/ui-tokens --filter @epignosis_llc/ui-icons --filter @epignosis_llc/ui-hub run build-storybook",
    "build-storybook:hub": "pnpm build-storybook && pnpm --filter @epignosis_llc/ui-hub assemble",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier -c .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.2"
  }
}
