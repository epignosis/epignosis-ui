{
  "name": "epignosis-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Epignosis shared UI workspace — tokens, React components, Vue components.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter @epignosis_llc/ui-tokens --filter @epignosis_llc/ui-react --filter @epignosis_llc/ui-vue run build",
    "storybook:react": "pnpm --filter @epignosis_llc/ui-react storybook",
    "storybook:vue": "pnpm --filter @epignosis_llc/ui-vue storybook",
    "storybook:tokens": "pnpm --filter @epignosis_llc/ui-tokens storybook",
    "storybook:all": "pnpm -r --parallel --filter @epignosis_llc/ui-react --filter @epignosis_llc/ui-vue --filter @epignosis_llc/ui-tokens run storybook",
    "build-storybook": "pnpm -r --filter @epignosis_llc/ui-react --filter @epignosis_llc/ui-vue --filter @epignosis_llc/ui-tokens run build-storybook"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
}
