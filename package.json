{
  "name": "epignosis-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Epignosis shared UI package — design tokens and React components, consumed directly from the repo.",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/theme/tokens.ts",
      "import": "./src/theme/tokens.ts",
      "require": "./src/theme/tokens.ts"
    },
    "./tokens.css": "./src/theme/tokens.css"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "sideEffects": [
    "**/*.css"
  ]
}
