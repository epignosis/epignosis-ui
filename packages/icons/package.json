{
  "name": "@epignosis_llc/ui-icons",
  "version": "0.1.0",
  "type": "module",
  "description": "Epignosis icon set as React components.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "license": "MIT",
  "author": "Epignosis LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epignosis/epignosis-ui.git",
    "directory": "packages/icons"
  },
  "homepage": "https://github.com/epignosis/epignosis-ui#readme",
  "bugs": {
    "url": "https://github.com/epignosis/epignosis-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "epignosis",
    "design-system",
    "icons",
    "svg",
    "react"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^19.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-svgr": "^4.5.0"
  }
}
